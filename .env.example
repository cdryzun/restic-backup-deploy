# ==============================================================================
# restic-backup-deploy 环境变量配置
# 复制此文件为 .env 并按需修改
# ==============================================================================

# ── 服务端配置 ────────────────────────────────────────────────
# rest-server 监听端口
RESTIC_PORT=8000

# rest-server 启动参数（直接拼接到命令行）
# 常用参数：
#   --prometheus             暴露 /metrics 端点（默认已启用）
#   --append-only            仅追加模式，防止删除历史备份（强烈推荐）
#   --private-repos          用户只能访问自己的仓库
#   --tls                    启用 TLS（需配置证书，见下方）
#   --prometheus-no-auth     /metrics 不需要认证（同步删除 prometheus.yml 中的 basic_auth）
#   --max-size 107374182400  限制总大小为 100GB
OPTIONS=--prometheus

# TLS 证书路径（启用 --tls 时需要）
# 将证书文件放置于 ./certs/ 目录：
#   ./certs/public_key   → TLS 证书
#   ./certs/private_key  → TLS 私钥

# ── 监控配置 ──────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# Prometheus 抓取 rest-server /metrics 时使用的密码
# 同步修改 ./config/metrics_password 文件内容
METRICS_PASSWORD=changeme_metrics

# Grafana 管理员账号
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana
