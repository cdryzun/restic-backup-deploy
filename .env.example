# ==============================================================================
# restic-backup-deploy 环境变量配置
# 复制此文件为 .env 并按需修改
# ==============================================================================

# ── 服务端配置 ────────────────────────────────────────────────
# rest-server 监听端口
RESTIC_PORT=8000

# 是否启用 TLS（需将证书放置于 ./certs/public_key 和 ./certs/private_key）
# TLS_ENABLED=true

# 额外启动参数（如 --append-only --private-repos --max-size 107374182400）
EXTRA_OPTIONS=

# ── 客户端连接配置 ─────────────────────────────────────────────
# 服务端地址（客户端脚本使用）
RESTIC_HOST=127.0.0.1

# ── 监控配置 ──────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# Grafana 管理员账号
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme_grafana
